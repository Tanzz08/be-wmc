{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },

  // TAMBAHKAN DUA BARIS INI:
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "prisma", "*.config.ts"]
}
